   "source": [
    "import numpy as np\n",
    "from sklearn.linear_model import LinearRegression\n",
    "import pickle\n",
    "\n",
    "# Data\n",
    "X = np.array([[1], [2], [3], [4], [5]])\n",
    "y = np.array([20, 40, 60, 80, 100])\n",
    "\n",
    "model = LinearRegression()\n",
    "model.fit(X, y)\n",
    "\n",
    "# Save model\n",
    "pickle.dump(model, open(\"model.pkl\", \"wb\"))"
   ]
  },
